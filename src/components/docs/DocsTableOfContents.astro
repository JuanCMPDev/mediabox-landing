---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  mobile?: boolean;
}

const { headings, mobile = false } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && mobile && (
  <!-- Mobile TOC (rendered inside drawer) -->
  <nav class="px-4 py-4">
    <ul class="space-y-1 border-l border-border-subtle">
      {tocHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-sm leading-relaxed transition-colors hover:text-text-primary border-l -ml-px py-1',
              heading.depth === 2
                ? 'pl-4 text-text-secondary border-transparent hover:border-accent/50'
                : 'pl-7 text-text-muted border-transparent hover:border-accent/30',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{tocHeadings.length > 0 && !mobile && (
  <!-- Desktop TOC -->
  <aside class="w-56 shrink-0 hidden xl:block">
    <nav class="sticky top-[96px] max-h-[calc(100vh-96px)] overflow-y-auto pb-8 pl-4">
      <h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">
        On this page
      </h4>
      <ul class="space-y-1 border-l border-border-subtle">
        {tocHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-xs leading-relaxed transition-colors hover:text-text-primary border-l -ml-px',
                heading.depth === 2
                  ? 'pl-4 text-text-secondary border-transparent hover:border-accent/50'
                  : 'pl-7 text-text-muted border-transparent hover:border-accent/30',
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}
