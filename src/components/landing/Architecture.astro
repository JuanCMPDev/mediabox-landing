---
import { services } from '../../data/services';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<section class="relative py-20 sm:py-28 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] sm:w-[600px] h-[400px] sm:h-[600px] glow-violet opacity-20"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight gradient-text">{t.architecture.title}</h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-text-secondary px-2">{t.architecture.subtitle}</p>
    </div>

    <!-- Architecture diagram -->
    <div class="max-w-4xl mx-auto">
      <!-- AI Client -->
      <div class="flex justify-center mb-6 sm:mb-8">
        <div class="glass-card rounded-xl sm:rounded-2xl px-5 sm:px-8 py-3 sm:py-4 text-center">
          <div class="text-[10px] sm:text-xs text-text-muted uppercase tracking-wider mb-1">{t.architecture.aiClient}</div>
          <div class="text-xs sm:text-sm font-medium text-text-primary">Claude / ChatGPT / Telegram</div>
        </div>
      </div>

      <!-- Connection line -->
      <div class="flex justify-center mb-6 sm:mb-8">
        <div class="w-px h-8 sm:h-12 bg-gradient-to-b from-border-visible to-accent/40"></div>
      </div>

      <!-- MCP Server -->
      <div class="flex justify-center mb-6 sm:mb-8">
        <div class="glass-card rounded-xl sm:rounded-2xl px-6 sm:px-10 py-4 sm:py-5 text-center border-accent/30" style="box-shadow: 0 0 40px rgba(139,92,246,0.1)">
          <div class="text-[10px] sm:text-xs text-accent-hover uppercase tracking-wider mb-1">{t.architecture.mcpServer}</div>
          <div class="text-base sm:text-lg font-semibold text-text-primary">25 MCP Tools</div>
          <div class="text-[10px] sm:text-xs text-text-muted mt-1">Express + OAuth2 + Streamable HTTP</div>
        </div>
      </div>

      <!-- Connection lines (fan out) -->
      <div class="flex justify-center mb-6 sm:mb-8">
        <div class="w-px h-6 sm:h-8 bg-gradient-to-b from-accent/40 to-border-visible"></div>
      </div>

      <!-- Services grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3">
        {services.map((service) => (
          <div class="glass-card rounded-lg sm:rounded-xl p-3 sm:p-4 text-center group hover:scale-[1.02] transition-all duration-300">
            <div
              class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full mx-auto mb-1.5 sm:mb-2 opacity-80 group-hover:opacity-100 transition-opacity"
              style={`background-color: ${service.color}; box-shadow: 0 0 12px ${service.color}40`}
            ></div>
            <div class="text-xs sm:text-sm font-medium text-text-primary">{service.name}</div>
            <div class="text-[10px] sm:text-xs text-text-muted mt-0.5">:{service.port}</div>
          </div>
        ))}
      </div>

      <!-- Connection line -->
      <div class="flex justify-center my-6 sm:my-8">
        <div class="w-px h-6 sm:h-8 bg-gradient-to-b from-border-visible to-highlight/40"></div>
      </div>

      <!-- Media Volume -->
      <div class="flex justify-center">
        <div class="glass-card rounded-xl sm:rounded-2xl px-4 sm:px-8 py-3 sm:py-4 text-center border-highlight/20">
          <div class="text-[10px] sm:text-xs text-highlight uppercase tracking-wider mb-1">{t.architecture.mediaVolume}</div>
          <div class="text-[10px] sm:text-sm text-text-secondary font-mono break-all sm:break-normal">/data/movies · /data/tv · /data/anime · /data/music</div>
        </div>
      </div>
    </div>
  </div>
</section>
