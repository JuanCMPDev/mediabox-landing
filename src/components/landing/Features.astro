---
import { features } from '../../data/features';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);

const iconMap: Record<string, string> = {
  server: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12H3a2 2 0 01-2-2V5a2 2 0 012-2h18a2 2 0 012 2v5a2 2 0 01-2 2h-2M5 12H3a2 2 0 00-2 2v5a2 2 0 002 2h18a2 2 0 002-2v-5a2 2 0 00-2-2h-2M5 12h14M7 8h.01M7 16h.01"/>',
  cpu: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m-2 6h2m14-6h2m-2 6h2M7 7h10v10H7z"/>',
  terminal: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 17l6-6-6-6m8 14h8"/>',
  bot: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2a2 2 0 012 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 017 7v3a2 2 0 01-2 2H5a2 2 0 01-2-2v-3a7 7 0 017-7h1V5.73A2 2 0 0112 2zM9 14a1 1 0 100-2 1 1 0 000 2zm6 0a1 1 0 100-2 1 1 0 000 2z"/>',
  globe: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zM2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>',
  shield: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
};
---

<section class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-10 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight gradient-text">{t.features.title}</h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-text-secondary px-2">{t.features.subtitle}</p>
    </div>

    <!-- Feature grid -->
    <div class="grid gap-3 sm:gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => {
        const featureData = t.features[feature.titleKey as keyof typeof t.features] as { title: string; description: string };
        return (
          <div
            class="glass-card rounded-xl sm:rounded-2xl p-5 sm:p-6 group"
            style={`animation-delay: ${i * 100}ms`}
          >
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-accent/20 transition-colors">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-accent-hover" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[feature.icon]} />
            </div>
            <h3 class="text-base sm:text-lg font-semibold text-text-primary mb-1.5 sm:mb-2">{featureData.title}</h3>
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed">{featureData.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
