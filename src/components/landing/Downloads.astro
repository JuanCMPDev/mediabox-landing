---
import { downloads, RELEASES_PAGE_URL, RELEASE_TAG } from '../../data/downloads';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);

// Brand SVG paths (24x24 viewBox, fill=currentColor) — recognisable per platform
// without depending on astro-icon's lucide allowlist.
const brandIcons: Record<string, string> = {
  windows:
    '<path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-13.051-1.351"/>',
  apple:
    '<path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>',
  linux:
    '<path d="M14.62 8.35c-.42 0-.85.16-1.16.5-.4.42-.34 1.16.16 1.45.34.18.84.16 1.18-.16.36-.32.4-.94.06-1.31-.06-.07-.13-.13-.24-.48zm-5.24 0c-.36 0-.69.18-.9.45-.34.4-.18 1.08.31 1.34.36.21.84.15 1.18-.13.32-.25.45-.79.21-1.18-.16-.27-.5-.48-.8-.48zM12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm-1.21 4.21c.92-.39 1.94-.42 2.86-.05.45.18.83.55.97 1.04.13.46.04.92-.21 1.32-.27.42-.6.7-1.13.99-.41.22-.74.49-.96.94-.18.36-.27.85-.27 1.27 0 .39.07.69.18.92.31.66.85 1.06 1.43 1.31.6.26 1.27.36 1.85.55.46.15.81.43 1.06.81.21.31.34.69.36 1.06.04.86-.45 1.66-1.13 2.18-.69.52-1.55.81-2.4.84-.83.03-1.62-.21-2.27-.65-.66-.45-1.16-1.13-1.45-1.85-.27-.69-.34-1.43-.21-2.13.13-.69.43-1.32.85-1.84.35-.43.74-.74 1.13-.97.4-.23.83-.4 1.18-.74.27-.27.43-.66.43-1.04 0-.36-.16-.69-.39-.94-.31-.31-.74-.45-1.21-.45-.42 0-.81.13-1.13.39-.36.27-.6.66-.74 1.04-.13.43-.13.86 0 1.31.13.43.4.81.74 1.06.13.09.07.31-.13.31h-.74c-.16 0-.31-.13-.34-.27-.13-.69-.04-1.4.27-2.04.27-.6.74-1.13 1.32-1.45z"/>',
};

function brandFor(id: string): string {
  if (id === 'windows') return brandIcons.windows;
  if (id === 'macos')   return brandIcons.apple;
  return brandIcons.linux;
}
---

<section id="downloads" class="relative overflow-hidden py-20 sm:py-28 scroll-mt-24">
  <div class="absolute inset-0 dot-grid opacity-40"></div>
  <div class="absolute top-0 right-1/4 w-[400px] h-[300px] glow-cyan opacity-20"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-10 sm:mb-14">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent-hover border border-accent/20 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        {t.downloads.badge}
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight gradient-text">{t.downloads.title}</h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-text-secondary max-w-2xl mx-auto px-2">{t.downloads.subtitle}</p>
    </div>

    <!-- Platform grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 auto-rows-fr max-w-5xl mx-auto">
      {downloads.map((asset) => {
        const platform = t.downloads.platforms[asset.id];
        return (
          <div class="glass-card rounded-xl sm:rounded-2xl p-5 sm:p-6 flex flex-col gap-4 transition-all hover:border-border-hover hover:-translate-y-0.5">
            <!-- Header: icon + title -->
            <div class="flex items-start gap-3">
              <div
                class="w-11 h-11 rounded-lg flex items-center justify-center shrink-0"
                style={`background: ${asset.color}1a; border: 1px solid ${asset.color}33;`}
              >
                <svg
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  style={`color: ${asset.color}`}
                  set:html={brandFor(asset.id)}
                />
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="text-sm sm:text-base font-semibold text-text-primary leading-tight">{platform.title}</h3>
                <p class="text-[11px] sm:text-xs text-text-muted mt-0.5">{platform.subtitle}</p>
              </div>
            </div>

            <!-- Hint (flex-1 so cards align) -->
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed flex-1">{platform.hint}</p>

            <!-- Action zone -->
            <div class="flex flex-col gap-2">
              <a
                href={asset.url}
                class="group/btn inline-flex items-center justify-between gap-2 w-full px-4 py-2.5 rounded-lg bg-accent hover:bg-accent-hover text-white text-sm font-medium transition-all hover:shadow-lg hover:shadow-accent/25"
              >
                <span class="inline-flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                  </svg>
                  {t.downloads.download}
                </span>
                <span class="text-[11px] font-mono opacity-80">{asset.extension} · {asset.size}</span>
              </a>
              {asset.altUrl && (
                <a
                  href={asset.altUrl}
                  class="text-[11px] text-text-muted hover:text-text-secondary text-center transition-colors"
                >
                  {t.downloads.altInstaller}
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Footer note -->
    <div class="mt-8 sm:mt-10 max-w-3xl mx-auto text-center">
      <p class="text-xs sm:text-sm text-text-muted leading-relaxed">
        <span class="text-text-secondary">{t.downloads.unsigned}</span>
        {' '}
        {t.downloads.unsignedDetail}
      </p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-xs">
        <a
          href={RELEASES_PAGE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-text-muted hover:text-text-primary transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {t.downloads.allReleases}
        </a>
        <span class="text-border-visible">·</span>
        <span class="text-text-muted font-mono">{RELEASE_TAG}</span>
      </div>
    </div>
  </div>
</section>
