---
import CopyButton from '../ui/CopyButton.tsx';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);

const claudeConfig = `{
  "mcpServers": {
    "mediabox": {
      "url": "https://your-domain.com/mcp"
    }
  }
}`;

const steps = [
  { ...t.quickstart.step1, code: 'npx create-mediabox', lang: 'bash' },
  { ...t.quickstart.step2, code: null, lang: null },
  { ...t.quickstart.step3, code: claudeConfig, lang: 'json' },
];
---

<section class="relative py-20 sm:py-28">
  <div class="absolute inset-0 dot-grid opacity-40"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-10 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight gradient-text">{t.quickstart.title}</h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-text-secondary px-2">{t.quickstart.subtitle}</p>
    </div>

    <!-- Steps -->
    <div class="max-w-3xl mx-auto space-y-6 sm:space-y-8">
      {steps.map((step, i) => (
        <div class="flex gap-3 sm:gap-6">
          <!-- Step number -->
          <div class="shrink-0">
            <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center">
              <span class="text-xs sm:text-sm font-bold text-accent-hover">{i + 1}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-px h-full bg-gradient-to-b from-accent/30 to-transparent mx-auto mt-2"></div>
            )}
          </div>

          <!-- Step content -->
          <div class="flex-1 min-w-0 pb-6 sm:pb-8">
            <h3 class="text-base sm:text-lg font-semibold text-text-primary mb-1">{step.title}</h3>
            <p class="text-xs sm:text-sm text-text-secondary mb-3 sm:mb-4">{step.description}</p>

            {step.code && (
              <div class="glass-card rounded-lg sm:rounded-xl overflow-hidden">
                <div class="flex items-center justify-between px-3 sm:px-4 py-2 border-b border-border-subtle">
                  <span class="text-[10px] sm:text-xs text-text-muted font-mono">{step.lang}</span>
                  <CopyButton text={step.code} client:idle />
                </div>
                <pre class="p-3 sm:p-4 text-xs sm:text-sm font-mono text-text-secondary overflow-x-auto"><code>{step.code}</code></pre>
              </div>
            )}

            {!step.code && (
              <div class="glass-card rounded-lg sm:rounded-xl p-3 sm:p-4">
                <div class="space-y-1.5 sm:space-y-2 text-xs sm:text-sm font-mono">
                  <div class="text-text-muted">? Where are you installing? <span class="text-accent-hover">VPS / Cloud server</span></div>
                  <div class="text-text-muted">? Base domain: <span class="text-text-secondary">media.example.com</span></div>
                  <div class="text-text-muted">? Email for Let's Encrypt: <span class="text-text-secondary">you@email.com</span></div>
                  <div class="text-text-muted">? Timezone: <span class="text-text-secondary">America/Bogota (detected)</span></div>
                  <div class="text-text-muted">? Movies path: <span class="text-text-secondary">./media/movies</span></div>
                  <div class="text-text-muted">? qBittorrent password: <span class="text-text-secondary">••••••••</span></div>
                  <div class="text-text-muted">? Jellyfin admin username: <span class="text-text-secondary">admin</span></div>
                  <div class="text-text-muted">? Jellyfin admin password: <span class="text-text-secondary">••••••••</span></div>
                  <div class="text-text-muted">? Enable Telegram bot? <span class="text-text-secondary">No</span></div>
                  <div class="text-text-muted">? Enable Bazarr? <span class="text-text-secondary">No</span></div>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
