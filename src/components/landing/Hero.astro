---
import CopyButton from '../ui/CopyButton.tsx';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);
const installCmd = 'npx create-mediabox';
---

<section class="relative overflow-hidden px-4 sm:px-6 py-20 sm:py-28 lg:py-36">
  <!-- Background effects -->
  <div class="absolute inset-0 dot-grid opacity-60"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] sm:w-[800px] sm:h-[600px] glow-violet opacity-40 animate-glow-pulse"></div>
  <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] glow-cyan opacity-20"></div>

  <div class="relative mx-auto max-w-5xl">
    <div class="flex flex-col items-center text-center">
      <!-- Badge -->
      <div class="animate-fade-in opacity-0 mb-6 sm:mb-8">
        <span class="inline-flex items-center gap-2 px-3 py-1 sm:px-4 sm:py-1.5 rounded-full text-xs font-medium bg-accent/10 text-accent-hover border border-accent/20">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          {t.hero.badge}
        </span>
      </div>

      <!-- Headline -->
      <h1 class="animate-fade-in opacity-0 delay-100 text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
        <span class="gradient-text">{t.hero.title}</span>
        <br />
        <span class="gradient-text-accent">{t.hero.titleAccent}</span>
      </h1>

      <!-- Description -->
      <p class="animate-fade-in opacity-0 delay-200 mt-4 sm:mt-6 max-w-xl sm:max-w-2xl text-base sm:text-lg text-text-secondary leading-relaxed px-2">
        {t.hero.description}
      </p>

      <!-- Install command -->
      <div class="animate-fade-in opacity-0 delay-300 mt-8 sm:mt-10 w-full max-w-sm sm:max-w-md">
        <p class="text-xs text-text-muted mb-2 uppercase tracking-wider">{t.hero.install}</p>
        <div class="glass-card rounded-xl px-4 py-2.5 sm:px-5 sm:py-3 flex items-center justify-between gap-3">
          <div class="flex items-center gap-2 sm:gap-3 min-w-0">
            <span class="text-accent shrink-0">$</span>
            <code class="text-sm font-mono text-text-primary truncate">{installCmd}</code>
          </div>
          <CopyButton text={installCmd} client:idle />
        </div>
        <a
          href="#downloads"
          class="mt-2 inline-block text-xs text-text-muted hover:text-accent-hover transition-colors"
        >
          {t.hero.orDownload}
        </a>
      </div>

      <!-- CTAs -->
      <div class="animate-fade-in opacity-0 delay-400 mt-6 sm:mt-8 flex flex-col sm:flex-row items-center gap-3 sm:gap-4 w-full sm:w-auto">
        <a
          href={locale === 'es' ? '/es/docs/getting-started/introduction' : '/docs/getting-started/introduction'}
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-2.5 sm:py-3 rounded-full bg-accent hover:bg-accent-hover text-white font-medium transition-all hover:shadow-lg hover:shadow-accent/25 text-sm sm:text-base"
        >
          {t.hero.cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="https://github.com/JuanCMPDev/mediabox-mcp"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-2.5 sm:py-3 rounded-full border border-border-visible text-text-secondary hover:text-text-primary hover:border-border-hover transition-all text-sm sm:text-base"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Terminal mockup -->
      <div class="animate-fade-in-up opacity-0 delay-500 mt-12 sm:mt-16 w-full max-w-3xl">
        <div class="glass-card rounded-xl sm:rounded-2xl overflow-hidden">
          <!-- Terminal header -->
          <div class="flex items-center gap-1.5 sm:gap-2 px-3 sm:px-4 py-2.5 sm:py-3 border-b border-border-subtle">
            <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-500/80"></div>
            <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-500/80"></div>
            <span class="ml-2 sm:ml-3 text-[10px] sm:text-xs text-text-muted font-mono">terminal</span>
          </div>
          <!-- Terminal body -->
          <div class="p-4 sm:p-6 font-mono text-xs sm:text-sm leading-relaxed text-left overflow-x-auto">
            <!-- Command -->
            <div class="flex gap-2">
              <span class="text-accent-hover shrink-0">$</span>
              <span class="text-text-primary">npx create-mediabox</span>
            </div>

            <!-- Wizard phases (matches real CLI output) -->
            <div class="mt-3 sm:mt-4 text-text-muted space-y-0.5 sm:space-y-1">
              <div class="text-cyan-400 font-semibold">🎬 Mediabox MCP — Setup Wizard</div>
              <div class="text-text-muted text-[10px] sm:text-xs">Configure your self-hosted media server stack</div>
            </div>
            <div class="mt-2 space-y-0.5 sm:space-y-1">
              <div class="text-green-400">✔ <span class="text-text-secondary">Phase 1 — Wizard complete</span></div>
              <div class="text-green-400">✔ <span class="text-text-secondary">Phase 2 — Files generated</span></div>
              <div class="text-green-400">✔ <span class="text-text-secondary">Phase 3 — Docker containers started (8/8 ready)</span></div>
              <div class="text-green-400">✔ <span class="text-text-secondary">Phase 4 — Services auto-configured</span></div>
            </div>

            <!-- Setup Complete table (matches real output) -->
            <div class="mt-3 sm:mt-4 text-cyan-400 font-semibold">Setup Complete!</div>
            <div class="mt-1 space-y-0.5 text-[10px] sm:text-xs">
              <div class="text-text-muted">Jellyfin      <span class="text-text-secondary">https://media.example.com</span>      <span class="text-green-400">Ready</span></div>
              <div class="text-text-muted">MCP Server    <span class="text-text-secondary">https://media.example.com/mcp</span>  <span class="text-green-400">Ready</span></div>
              <div class="text-text-muted">Sonarr        <span class="text-text-secondary">https://sonarr.media.example.com</span>  <span class="text-green-400">Ready</span></div>
            </div>
            <div class="mt-2 text-text-muted text-[10px] sm:text-xs">
              Next: Add indexers in Prowlarr → <span class="text-highlight">https://prowlarr.media.example.com</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
