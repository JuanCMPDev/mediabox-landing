---
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: string;
}

const locale = (Astro.props.locale ?? 'en') as Locale;
const t = useTranslations(locale);
---

<footer class="border-t border-border-subtle">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-8 sm:py-12">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
      <div class="flex items-center gap-2.5">
        <img src="/logo.svg" alt="Mediabox" class="h-14 w-14 rounded-lg" />
        <span class="text-xs sm:text-sm text-text-secondary">{t.footer.description}</span>
      </div>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs sm:text-sm text-text-muted">
        <span>{t.footer.builtBy} <a href="https://github.com/JuanCMPDev" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-hover transition-colors">@JuanCMPDev</a></span>
        <span class="hidden sm:inline text-border-visible">|</span>
        <a
          href="https://github.com/JuanCMPDev/mediabox-mcp/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-text-secondary transition-colors"
        >
          {t.footer.license}
        </a>
        <span class="hidden sm:inline text-border-visible">|</span>
        <a
          href="https://github.com/JuanCMPDev/mediabox-mcp"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-text-secondary transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
